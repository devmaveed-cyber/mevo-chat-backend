PORT=5001
NODE_ENV=development

# Dedicated Mevo Chat Atlas project (recommended)
# Run: atlas auth login && bash scripts/setup-mevo-atlas.sh
MONGODB_URI=mongodb+srv://<username>:<password>@mevocluster0.example.mongodb.net/mevo_chat?retryWrites=true&w=majority&appName=MevoCluster0

JWT_SECRET=change_this_to_a_long_random_secret_key
JWT_EXPIRES_IN=7d

# Same Agora project as PK Matchz (App ID is public; certificate stays server-side only)
AGORA_APP_ID=769762a4f6ee4622ab070e224064c117
AGORA_APP_CERTIFICATE=your_agora_app_certificate

CLIENT_ORIGIN=*
